<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="V5__create_invoice_outbox_tasks_table" author="order-service">
        <createTable tableName="invoice_outbox_tasks">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_invoice_outbox_tasks_order_id"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="retry_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME(6)">
                <constraints nullable="false"/>
            </column>
            <column name="processed_at" type="DATETIME(6)"/>
            <column name="version" type="BIGINT"/>
        </createTable>

        <createIndex tableName="invoice_outbox_tasks" indexName="idx_invoice_outbox_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
